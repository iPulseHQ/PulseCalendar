{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PulseCalendar",
  "version": "0.2.0",
  "identifier": "com.arjan.pulsecalendar",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PulseCalendar",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "visible": true,
        "hiddenTitle": false,
        "decorations": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "tooltip": "PulseCalendar"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "icons/nsis-header.bmp",
        "sidebarImage": "icons/nsis-sidebar.bmp",
        "installerIcon": "icons/installer-icon.ico",
        "installMode": "perMachine",
        "languages": [
          "English",
          "Dutch"
        ],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": [
          "pulsecalendar"
        ]
      }
    },
    "updater": {
      "active": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg0OERGQjMwRDhBQkZCREMKUldUYys2dllNUHVOaEkzRFZCUTJvYnpvM1NFRjUybFdoSG5vQUtJMDlMUWtBMlA1cDJJRy9WNWQK",
      "endpoints": [
        "https://pulsecalendar.app/api/releases/latest"
      ]
    }
  }
}